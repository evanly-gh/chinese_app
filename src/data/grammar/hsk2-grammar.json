  {
    "id": "gr_hsk2_014",
    "level": 2,
    "title": "Then/right away with 就 (jiù)",
    "pattern": "Condition/Time + 就 + Verb",
    "explanation": "就 has several uses: it indicates something happens quickly or sooner than expected ('right away'), links a condition to a consequence ('then'), or expresses immediacy. It always precedes the verb.",
    "examples": [
      {
        "simplified": "他一回家就吃饭。",
