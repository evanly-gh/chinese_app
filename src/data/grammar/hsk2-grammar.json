[
  {
    "id": "gr_hsk2_001",
    "level": 2,
    "title": "Comparison with 比 (bǐ)",
    "pattern": "A + 比 + B + Adjective",
    "explanation": "比 is used to make comparisons meaning 'A is more [adjective] than B'. The adjective comes after B. Do not add 更 (gèng) or 非常 after 比 comparisons.",
    "examples": [
      {
        "simplified": "他比我高。",
        "traditional": "他比我高。",
        "pinyin": "Tā bǐ wǒ gāo.",
        "english": "He is taller than me."
      },
      {
        "simplified": "今天比昨天冷。",
        "traditional": "今天比昨天冷。",
        "pinyin": "Jīntiān bǐ zuótiān lěng.",
        "english": "Today is colder than yesterday."
      }
    ],
    "fillBlanks": [
      {
        "sentence": "苹果___橙子甜。",
        "answer": "比",
        "distractors": ["和", "跟", "对"],
        "english": "Apples are sweeter than oranges."
      },
      {
        "sentence": "她___我大两岁。",
        "answer": "比",
        "distractors": ["和", "跟", "是"],
        "english": "She is two years older than me."
      },
      {
        "sentence": "这个___那个便宜。",
        "answer": "比",
        "distractors": ["和", "是", "有"],
        "english": "This one is cheaper than that one."
      }
    ],
    "mcqSentences": [
      {
        "correct": "他比我跑得快。",
        "wrong": ["他比我更快。", "他比我跑得很快。", "他比我非常快。"],
        "english": "He runs faster than me."
      },
      {
        "correct": "北京比上海冷。",
        "wrong": ["北京和上海冷。", "北京比上海更冷。", "北京是上海冷。"],
        "english": "Beijing is colder than Shanghai."
      }
    ]
  },
  {
    "id": "gr_hsk2_002",
    "level": 2,
    "title": "A little with 一点儿 (yīdiǎnr)",
    "pattern": "Verb + 一点儿 / Adjective + 一点儿 (in comparisons)",
    "explanation": "一点儿 means 'a little' or 'a bit'. After a verb it means 'a little (of something)'. In comparisons it follows the adjective to mean 'a little more [adj]'.",
    "examples": [
      {
        "simplified": "请说慢一点儿。",
        "traditional": "請說慢一點兒。",
        "pinyin": "Qǐng shuō màn yīdiǎnr.",
        "english": "Please speak a little slower."
      },
      {
        "simplified": "我喝了一点儿水。",
        "traditional": "我喝了一點兒水。",
        "pinyin": "Wǒ hē le yīdiǎnr shuǐ.",
        "english": "I drank a little water."
      }
    ],
    "fillBlanks": [
      {
