  {
    "id": "gr_hsk2_007",
    "level": 2,
    "title": "Ability/Future with 会 (huì)",
    "pattern": "Subject + 会 + Verb",
    "explanation": "会 has two main uses: (1) learned ability — 'can/know how to' for skills acquired through learning; (2) future possibility — 'will/would' to predict future events.",
    "examples": [
      {
        "simplified": "我会说中文。",
        "traditional": "我會說中文。",
        "pinyin": "Wǒ huì shuō Zhōngwén.",
