  {
    "id": "gr_hsk2_008",
    "level": 2,
    "title": "Physical ability with 能 (néng)",
    "pattern": "Subject + 能 + Verb",
    "explanation": "能 expresses physical or circumstantial ability — being able to do something due to natural capacity or situation. It is different from 会 (learned skill) and 可以 (permission).",
