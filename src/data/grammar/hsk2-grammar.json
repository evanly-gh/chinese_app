  {
    "id": "gr_hsk2_005",
    "level": 2,
    "title": "Past experience with 过 (guò)",
    "pattern": "Verb + 过 (+ Object)",
    "explanation": "过 after a verb indicates a past experience, meaning 'have done [verb] before'. It focuses on whether an experience has been had, not when it happened. Negated with 没.",
    "examples": [
      {
        "simplified": "我去过北京。",
        "traditional": "我去過北京。",
        "pinyin": "Wǒ qù guò Běijīng.",
        "english": "I have been to Beijing before."
      },
      {
        "simplified": "你吃过北京烤鸭吗？",
        "traditional": "你吃過北京烤鴨嗎？",
        "pinyin": "Nǐ chī guò Běijīng kǎoyā ma?",
        "english": "Have you ever eaten Peking duck?"
      }
    ],
    "fillBlanks": [
      {
        "sentence": "我没学___中文。",
        "answer": "过",
        "distractors": ["了", "着", "得"],
        "english": "I have never studied Chinese before."
      },
      {
        "sentence": "他见___那个人吗？",
        "answer": "过",
        "distractors": ["了", "着", "得"],
        "english": "Has he met that person before?"
      },
      {
        "sentence": "她来___我家。",
        "answer": "过",
        "distractors": ["了", "着", "得"],
        "english": "She has visited my home before."
