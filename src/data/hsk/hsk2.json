  {"id":"hsk2_072","level":2,"simplified":"您","traditional":"您","pinyin":"nín","english":"you (respectful form)","partOfSpeech":"pronoun","exampleSimplified":"您好！","exampleTraditional":"您好！","examplePinyin":"Nín hǎo!","exampleEnglish":"Hello! (respectful)"},
  {"id":"hsk2_073","level":2,"simplified":"牛奶","traditional":"牛奶","pinyin":"niúnǎi","english":"milk","partOfSpeech":"noun","exampleSimplified":"我每天早上喝牛奶。","exampleTraditional":"我每天早上喝牛奶。","examplePinyin":"Wǒ měitiān zǎoshang hē niúnǎi.","exampleEnglish":"I drink milk every morning."},
  {"id":"hsk2_074","level":2,"simplified":"女","traditional":"女","pinyin":"nǚ","english":"female; woman","partOfSpeech":"noun/adjective","exampleSimplified":"她是女生。","exampleTraditional":"她是女生。","examplePinyin":"Tā shì nǚshēng.","exampleEnglish":"She is a female student."},
