  {"id":"hsk2_089","level":2,"simplified":"生日","traditional":"生日","pinyin":"shēngrì","english":"birthday","partOfSpeech":"noun","exampleSimplified":"今天是我的生日。","exampleTraditional":"今天是我的生日。","examplePinyin":"Jīntiān shì wǒ de shēngrì.","exampleEnglish":"Today is my birthday."},
  {"id":"hsk2_090","level":2,"simplified":"时间","traditional":"時間","pinyin":"shíjiān","english":"time","partOfSpeech":"noun","exampleSimplified":"我没有时间。","exampleTraditional":"我沒有時間。","examplePinyin":"Wǒ méiyǒu shíjiān.","exampleEnglish":"I don't have time."},
  {"id":"hsk2_091","level":2,"simplified":"事情","traditional":"事情","pinyin":"shìqing","english":"matter; thing; affair","partOfSpeech":"noun","exampleSimplified":"你有什么事情？","exampleTraditional":"你有什麼事情？","examplePinyin":"Nǐ yǒu shénme shìqing?","exampleEnglish":"What's the matter?"},
  {"id":"hsk2_092","level":2,"simplified":"手表","traditional":"手錶","pinyin":"shǒubiǎo","english":"watch; wristwatch","partOfSpeech":"noun","exampleSimplified":"他的手表很贵。","exampleTraditional":"他的手錶很貴。","examplePinyin":"Tā de shǒubiǎo hěn guì.","exampleEnglish":"His watch is very expensive."},
