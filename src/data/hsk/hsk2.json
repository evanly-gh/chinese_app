  {"id":"hsk2_134","level":2,"simplified":"再","traditional":"再","pinyin":"zài","english":"again; once more","partOfSpeech":"adverb","exampleSimplified":"请再说一遍。","exampleTraditional":"請再說一遍。","examplePinyin":"Qǐng zài shuō yī biàn.","exampleEnglish":"Please say it again."},
