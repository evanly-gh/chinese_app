  {"id":"hsk2_132","level":2,"simplified":"元","traditional":"元","pinyin":"yuán","english":"yuan (Chinese currency)","partOfSpeech":"measure word","exampleSimplified":"这个十元。","exampleTraditional":"這個十元。","examplePinyin":"Zhège shí yuán.","exampleEnglish":"This is ten yuan."},
