  {"id":"hsk2_078","level":2,"simplified":"票","traditional":"票","pinyin":"piào","english":"ticket","partOfSpeech":"noun","exampleSimplified":"我买了两张票。","exampleTraditional":"我買了兩張票。","examplePinyin":"Wǒ mǎi le liǎng zhāng piào.","exampleEnglish":"I bought two tickets."},
  {"id":"hsk2_079","level":2,"simplified":"妻子","traditional":"妻子","pinyin":"qīzi","english":"wife","partOfSpeech":"noun","exampleSimplified":"他的妻子很漂亮。","exampleTraditional":"他的妻子很漂亮。","examplePinyin":"Tā de qīzi hěn piàoliang.","exampleEnglish":"His wife is very beautiful."},
  {"id":"hsk2_080","level":2,"simplified":"起床","traditional":"起床","pinyin":"qǐ chuáng","english":"to get up; to get out of bed","partOfSpeech":"verb phrase","exampleSimplified":"我七点起床。","exampleTraditional":"我七點起床。","examplePinyin":"Wǒ qī diǎn qǐ chuáng.","exampleEnglish":"I get up at seven o'clock."},
  {"id":"hsk2_081","level":2,"simplified":"千","traditional":"千","pinyin":"qiān","english":"thousand","partOfSpeech":"numeral","exampleSimplified":"这件衣服一千块。","exampleTraditional":"這件衣服一千塊。","examplePinyin":"Zhè jiàn yīfu yī qiān kuài.","exampleEnglish":"This piece of clothing costs one thousand yuan."},
  {"id":"hsk2_082","level":2,"simplified":"铅笔","traditional":"鉛筆","pinyin":"qiānbǐ","english":"pencil","partOfSpeech":"noun","exampleSimplified":"请用铅笔写。","exampleTraditional":"請用鉛筆寫。","examplePinyin":"Qǐng yòng qiānbǐ xiě.","exampleEnglish":"Please write with a pencil."},
  {"id":"hsk2_083","level":2,"simplified":"晴","traditional":"晴","pinyin":"qíng","english":"sunny; clear (weather)","partOfSpeech":"adjective","exampleSimplified":"今天天气很晴。","exampleTraditional":"今天天氣很晴。","examplePinyin":"Jīntiān tiānqì hěn qíng.","exampleEnglish":"The weather is very sunny today."},
  {"id":"hsk2_084","level":2,"simplified":"让","traditional":"讓","pinyin":"ràng","english":"to let; to allow; to make","partOfSpeech":"verb","exampleSimplified":"请让我看看。","exampleTraditional":"請讓我看看。","examplePinyin":"Qǐng ràng wǒ kànkan.","exampleEnglish":"Please let me have a look."},
  {"id":"hsk2_085","level":2,"simplified":"日记","traditional":"日記","pinyin":"rìjì","english":"diary; journal","partOfSpeech":"noun","exampleSimplified":"我每天写日记。","exampleTraditional":"我每天寫日記。","examplePinyin":"Wǒ měitiān xiě rìjì.","exampleEnglish":"I write in my diary every day."},
