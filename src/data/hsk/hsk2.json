  {"id":"hsk2_100","level":2,"simplified":"跳舞","traditional":"跳舞","pinyin":"tiào wǔ","english":"to dance","partOfSpeech":"verb phrase","exampleSimplified":"她跳舞跳得很好。","exampleTraditional":"她跳舞跳得很好。","examplePinyin":"Tā tiàowǔ tiào de hěn hǎo.","exampleEnglish":"She dances very well."},
