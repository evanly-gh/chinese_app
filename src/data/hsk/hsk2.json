  {"id":"hsk2_119","level":2,"simplified":"颜色","traditional":"顏色","pinyin":"yánsè","english":"color","partOfSpeech":"noun","exampleSimplified":"你喜欢什么颜色？","exampleTraditional":"你喜歡什麼顏色？","examplePinyin":"Nǐ xǐhuān shénme yánsè?","exampleEnglish":"What color do you like?"},
