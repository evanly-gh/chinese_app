  {"id":"hsk2_095","level":2,"simplified":"送","traditional":"送","pinyin":"sòng","english":"to send; to give (as a gift); to see off","partOfSpeech":"verb","exampleSimplified":"我送你一个礼物。","exampleTraditional":"我送你一個禮物。","examplePinyin":"Wǒ sòng nǐ yī gè lǐwù.","exampleEnglish":"I'll give you a gift."},
